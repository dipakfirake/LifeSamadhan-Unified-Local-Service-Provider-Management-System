import React from 'react';
import { Link } from 'react-router-dom';

export default function Navbar({ user, onLogout }) {
  return (
    <header className="container" style={{ paddingTop: 18 }}>
      <div className="navbar">
        <div className="brand"><Link to="/">LifeSamadhan</Link></div>
        <div className="nav-links">
          <Link className="nav-link" to="/">Home</Link>
          <Link className="nav-link" to="/about">About</Link>
          <Link className="nav-link" to="/contact">Contact</Link>
          {!user && <Link className="nav-link nav-cta" to="/register">Sign up</Link>}
          {!user && <Link className="nav-link" to="/login">Sign in</Link>}
          {user && <Link className="nav-link" to="/dashboard">Dashboard</Link>}
          {user && <button className="nav-logout" onClick={onLogout}>Logout</button>}
        </div>
      </div>
    </header>
  );
}
