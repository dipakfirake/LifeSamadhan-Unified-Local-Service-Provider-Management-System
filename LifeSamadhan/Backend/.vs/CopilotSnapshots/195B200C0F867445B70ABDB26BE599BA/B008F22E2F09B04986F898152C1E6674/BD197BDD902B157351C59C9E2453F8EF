import React from 'react';
import { Link } from 'react-router-dom';

export default function Navbar({ role, userName, onLogout }) {
  const isProvider = role === 'SERVICEPROVIDER';
  const isAdmin = role === 'ADMIN';

  return (
    <header className="container" style={{ paddingTop: 18 }}>
      <div className="navbar">
        <div className="brand"><Link to="/">LifeSamadhan</Link></div>
        <div className="nav-links">
          <Link className="nav-link" to="/">Home</Link>
          <Link className="nav-link" to="/about">About</Link>
          <Link className="nav-link" to="/contact">Contact</Link>

          {!role && <Link className="nav-link nav-cta" to="/register">Sign up</Link>}
          {!role && <Link className="nav-link" to="/login">Sign in</Link>}

          {role && isProvider && <Link className="nav-link" to="/provider">Provider</Link>}
          {role && !isProvider && <Link className="nav-link" to="/dashboard">Dashboard</Link>}

          {userName && <div style={{ padding: '6px 10px', borderRadius: 8, background: '#eef2ff', color: '#0b5cff' }}>Hi, {userName}</div>}

          {role && <button className="nav-logout" onClick={onLogout}>Logout</button>}
          {isAdmin && <Link className="nav-link" to="/admin">Admin</Link>}
        </div>
      </div>
    </header>
  );
}
