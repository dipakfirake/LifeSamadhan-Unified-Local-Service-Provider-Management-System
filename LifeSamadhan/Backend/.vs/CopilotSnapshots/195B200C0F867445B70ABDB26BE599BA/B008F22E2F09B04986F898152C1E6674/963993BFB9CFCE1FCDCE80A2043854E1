import React, { useState, useEffect } from 'react';
import { Routes, Route, useNavigate } from 'react-router-dom';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import Landing from './Landing';
import About from './About';
import Contact from './Contact';
import Register from './Register';
import Login from './Login';
import PaymentForm from '../components/PaymentForm';
import ServiceDetails from './ServiceDetails';
import Dashboard from './Dashboard';
import Analytics from './dashboard/Analytics';
import Settings from './dashboard/Settings';
import ProviderDashboard from './provider/ProviderDashboard';
import AdminDashboard from './admin/AdminDashboard';

const API_BASE = 'http://localhost:5055/api';

export default function AppLayout(){
  const [token, setToken] = useState(localStorage.getItem('api_token') || '');
  const [role, setRole] = useState(localStorage.getItem('api_role') || '');
  const [userName, setUserName] = useState('');
  const navigate = useNavigate();

  useEffect(() => { if (token) fetchProfile(); }, [token]);

  async function fetchProfile(){
    try{
      let url = '/customer/profile';
      if (role === 'SERVICEPROVIDER') url = '/provider/profile';
      if (role === 'ADMIN') url = '/customer/profile';

      const res = await fetch(`${API_BASE}${url}`, { headers: { Authorization: `Bearer ${token}` } });
      if (!res.ok) return;
      const data = await res.json();
      if (data.user) setUserName(data.user.name);
      else if (data?.user) setUserName(data.user.name);
    }catch(err){ console.error(err); }
  }

  const handleLogin = (t, r) =>{
    setToken(t); setRole(r); localStorage.setItem('api_token', t); localStorage.setItem('api_role', r); fetchProfile(); if (r === 'SERVICEPROVIDER') navigate('/provider'); else if (r === 'ADMIN') navigate('/admin'); else navigate('/dashboard');
  };

  const handleLogout = () => { setToken(''); setRole(''); setUserName(''); localStorage.removeItem('api_token'); localStorage.removeItem('api_role'); navigate('/'); };

  const onNavigate = (to) => {
    // if absolute path provided
    if (!to) return;
    if (to.startsWith('/')) { navigate(to); return; }
    // keywords
    if (to === 'register') navigate('/register');
    else if (to === 'login') navigate('/login');
    else if (to === 'dashboard') navigate('/dashboard');
    else navigate('/');
  };

  return (
    <div>
      <Navbar role={role} userName={userName} onLogout={handleLogout} />
      <div className="container">
        <Routes>
          <Route path="/" element={<Landing onNavigate={onNavigate} token={token} />} />
          <Route path="/about" element={<About />} />
          <Route path="/contact" element={<Contact />} />
          <Route path="/register" element={<Register onRegistered={() => navigate('/login')} />} />
          <Route path="/login" element={<Login onLogged={handleLogin} />} />
          <Route path="/service/:id" element={<ServiceDetails token={token} />} />

          <Route path="/dashboard" element={token && role !== 'SERVICEPROVIDER' ? <Dashboard token={token} /> : <div>Please login to access dashboard</div>} />
          <Route path="/dashboard/analytics" element={token ? <Analytics token={token} /> : <div>Please login to access this page</div>} />
          <Route path="/dashboard/settings" element={token ? <Settings token={token} /> : <div>Please login to access this page</div>} />

          <Route path="/provider/*" element={role === 'SERVICEPROVIDER' ? <ProviderDashboard token={token} /> : <div>Access denied</div>} />
          <Route path="/admin/*" element={role === 'ADMIN' ? <AdminDashboard token={token} /> : <div>Access denied</div>} />
        </Routes>
      </div>
      <Footer />
    </div>
  );
}
