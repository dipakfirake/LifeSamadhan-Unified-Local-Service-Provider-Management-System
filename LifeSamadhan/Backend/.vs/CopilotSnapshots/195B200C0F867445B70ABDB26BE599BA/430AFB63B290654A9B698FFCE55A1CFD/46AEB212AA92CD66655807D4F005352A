body { font-family: Arial, Helvetica, sans-serif; margin: 0; padding: 20px; background: #f6f8fa; }
.container { max-width: 800px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
input, textarea, select, button { font-size: 14px; padding: 8px; margin: 6px 0; }
button { cursor: pointer; }
.payment-card { border: 1px solid #eee; padding: 10px; border-radius: 6px; margin-top: 10px; }
