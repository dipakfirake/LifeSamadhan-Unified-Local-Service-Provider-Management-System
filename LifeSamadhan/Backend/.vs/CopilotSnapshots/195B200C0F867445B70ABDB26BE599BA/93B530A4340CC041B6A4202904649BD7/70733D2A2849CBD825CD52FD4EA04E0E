:root{
  --bg: #f6f8fa;
  --card: #ffffff;
  --muted: #6b7280;
  --primary: #0b5cff;
  --glass: rgba(255,255,255,0.6);
}
*{box-sizing:border-box}
body{ margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; background: var(--bg); color:#111827 }
.container{ max-width: 1100px; margin: 28px auto; background: transparent; padding: 0 20px }
.app-card{ background: var(--card); padding: 20px; border-radius: 14px; box-shadow: 0 10px 30px rgba(2,6,23,0.06); }

/* Navbar */
.navbar{ display:flex; justify-content:space-between; align-items:center; padding:18px 0 }
.brand{ font-weight:700; font-size:20px; color: #0b5cff }
.nav-links{ display:flex; gap:12px; align-items:center }
.nav-link{ color:#374151; text-decoration:none; padding:8px 10px; border-radius:8px }
.nav-cta{ padding:8px 12px; background:var(--primary); color:#fff; border-radius:10px; text-decoration:none }
.nav-logout{ padding:8px 12px; background:#ef4444; color:#fff; border-radius:10px; border:none }

/* Hero */
.hero{ background: linear-gradient(180deg, rgba(11,92,255,0.06), rgba(240,246,255,1)); padding:48px 0; border-radius:14px; margin-bottom:18px }
.hero-inner{ display:flex; gap:20px; align-items:center; justify-content:space-between }
.hero-left{ flex:1 }
.hero-title{ font-size:34px; margin:0 0 8px }
.hero-sub{ color:var(--muted); margin:0 0 16px }
.hero-actions{ display:flex; gap:12px }
.search-bar{ display:flex; gap:8px; margin-top:14px }
.search-input{ padding:12px 14px; border-radius:12px; border:1px solid #e6edf8; width:100%; }
.search-btn{ padding:12px 16px; border-radius:12px; background:var(--primary); color:#fff; border:none }

/* Services grid */
.services-grid{ display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap:16px }
.service-card{ background:var(--card); border-radius:12px; padding:16px; box-shadow: 0 8px 20px rgba(2,6,23,0.04); border:1px solid #f1f5f9 }
.service-title{ font-weight:700; font-size:16px }
.service-desc{ color:var(--muted); margin-top:8px; font-size:14px }
.service-meta{ display:flex; justify-content:space-between; align-items:center; margin-top:12px }
.service-btn{ padding:8px 12px; border-radius:8px; background:var(--primary); color:#fff; border:none }

/* Footer */
.footer{ margin-top:40px; padding:24px 0; text-align:center; color:#6b7280 }

@media (max-width:720px){ .hero-inner{ flex-direction:column; text-align:center } }
