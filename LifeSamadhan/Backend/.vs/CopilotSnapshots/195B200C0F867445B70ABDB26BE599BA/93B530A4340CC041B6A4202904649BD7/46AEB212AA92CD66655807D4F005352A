:root{
  --bg: #f6f8fa;
  --card: #ffffff;
  --muted: #6b7280;
  --primary: #0b5cff;
}
body{ margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; background: var(--bg); color:#111827 }
.container{ max-width: 960px; margin: 24px auto; background: var(--card); padding: 20px; border-radius: 10px; box-shadow: 0 6px 26px rgba(15,23,42,0.06) }
button{ padding:8px 12px; background:var(--primary); color:#fff; border:none; border-radius:8px }
input, textarea, select{ border:1px solid #e6e6e6; padding:10px; border-radius:8px }
nav a{ color:inherit }
